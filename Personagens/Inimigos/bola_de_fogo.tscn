[sub_resource type="Shader" id="Shader_wdr77"]
code = "shader_type spatial;

// --- Parâmetros ---

// As duas texturas de água para transicionar.
uniform sampler2D water_texture_a : source_color, filter_nearest;
uniform sampler2D water_texture_b : source_color, filter_nearest;

// Texturas de ruído/normal map para distorção e padrão de transição
uniform sampler2D distortion_noise_1;
uniform sampler2D distortion_noise_2;
uniform sampler2D dissolve_noise;

// Textura de Emissão (brilho)
uniform sampler2D emission_texture : source_color;
// Força do brilho (requer WorldEnvironment com Glow ativado)
uniform float emission_strength : hint_range(0.0, 100.0) = 2.0;

// Intensidade da distorção da água
uniform float distortion_strength : hint_range(0.0, 0.1) = 0.05;
// Velocidade da distorção (as \"ondas\" se movendo)
uniform float distortion_speed : hint_range(0.0, 1.0) = 0.1;

// NOVO: Velocidade que as próprias texturas de água rolam
uniform float water_scroll_speed : hint_range(0.0, 0.5) = 0.05;

// Velocidade da transição de A para B (o \"dissolver\" geral)
uniform float transition_speed : hint_range(0.1, 2.0) = 0.2;
// Suavidade da borda do \"dissolve\"
uniform float transition_softness : hint_range(0.0, 1.0) = 0.2;


void fragment() {
	// 1. Calcular o offset de distorção
	vec2 distortion_uv1 = UV + vec2(TIME * distortion_speed, TIME * distortion_speed * 0.7);
	vec2 distortion_uv2 = UV + vec2(-TIME * distortion_speed * 0.5, TIME * distortion_speed * 1.2);

	vec2 distortion_offset1 = texture(distortion_noise_1, distortion_uv1).rg * 2.0 - 1.0;
	vec2 distortion_offset2 = texture(distortion_noise_2, distortion_uv2).rg * 2.0 - 1.0;

	vec2 total_distortion = (distortion_offset1 + distortion_offset2) * 0.5 * distortion_strength;

	// NOVO: Calcular o offset de scroll para as texturas de água base
	vec2 scroll_offset = vec2(TIME * water_scroll_speed, TIME * water_scroll_speed * 0.5); // Scroll em X e Y

	// 2. Aplicar a distorção E o scroll aos UVs das texturas de água
	vec2 final_water_uv = UV + total_distortion + scroll_offset; // Combinando scroll e distorção

	// 3. Ler as cores das texturas de água distorcidas e com scroll
	vec3 color_a = texture(water_texture_a, final_water_uv).rgb;
	vec3 color_b = texture(water_texture_b, final_water_uv).rgb;

	// 4. Calcular o fator de transição (dissolve)
	// O ruído para o dissolve também pode ser distorcido e com scroll para um efeito mais \"líquido\"
	// Usamos final_water_uv aqui para que o dissolve siga o movimento geral da água
	float dissolve_noise_value = texture(dissolve_noise, final_water_uv).r;

	// O limite da transição animado de 0.0 a 1.0 e vice-versa
	float threshold = (sin(TIME * transition_speed) + 1.0) / 2.0;

	// Usa smoothstep para criar uma borda suave
	float blend_factor = smoothstep(threshold - transition_softness, threshold + transition_softness, dissolve_noise_value);

	// 5. Misturar as duas texturas de água
	vec3 final_color = mix(color_a, color_b, blend_factor);

	ALBEDO = final_color;

	// 6. Aplicar Emissão (Brilho)
	// Lemos a textura de emissão usando os mesmos UVs distorcidos e com scroll
	// Isso faz com que a \"espuma\" ou \"brilho\" se movam com as ondas.
	float emission_mask = texture(emission_texture, final_water_uv).r;
	
	// O brilho será a cor final da água, multiplicada pela máscara de emissão e pela força.
	EMISSION = final_color * emission_mask * emission_strength;
}"

