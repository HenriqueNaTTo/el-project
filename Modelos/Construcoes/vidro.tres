[gd_resource type="ShaderMaterial" format=3 uid="uid://b2i2h4u0bqb6d"]

[sub_resource type="Shader" id="Shader_noukl"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_burley, specular_schlick_ggx;

// --- Parâmetros de aparência ---
uniform vec4 glass_tint : source_color = vec4(0.85, 0.92, 1.0, 1.0);
uniform float transparency : hint_range(0.0, 1.0) = 0.08;
uniform float roughness : hint_range(0.0, 1.0) = 0.0;
uniform float ior : hint_range(1.0, 2.5) = 1.45;

// --- Refração ---
uniform float refraction_strength : hint_range(0.0, 0.1) = 0.025;
uniform sampler2D screen_texture : hint_screen_texture, filter_linear_mipmap;
uniform sampler2D depth_texture : hint_depth_texture, filter_linear_mipmap;

// --- Fresnel ---
uniform float fresnel_power : hint_range(1.0, 8.0) = 4.0;
uniform float fresnel_intensity : hint_range(0.0, 1.0) = 1.0;

// --- Aberração cromática ---
uniform float chromatic_aberration : hint_range(0.0, 0.02) = 0.004;

// --- Fosco / Blur ---
uniform float blur_amount : hint_range(0.0, 1.0) = 0.0;

// --- Reflexo especular ---
uniform float metallic : hint_range(0.0, 1.0) = 0.0;
uniform float specular_strength : hint_range(0.0, 1.0) = 0.85;

// --- Absorção ---
uniform vec4 absorption_color : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform float absorption_density : hint_range(0.0, 5.0) = 0.0;

// --- Normal map ---
uniform sampler2D normal_map_tex : hint_normal;
uniform float normal_map_strength : hint_range(0.0, 2.0) = 0.0;
uniform bool use_normal_map = false;

// --- Emissão ---
uniform bool use_emission = false;
uniform vec4 emission_color : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform float emission_energy : hint_range(0.0, 16.0) = 1.0;

// Padrão da emissão
// 0 = cor sólida
// 1 = fresnel (brilha nas bordas — neon/holo)
// 2 = núcleo (brilha no centro — plasma/magma)
// 3 = textura
uniform int emission_pattern : hint_range(0, 3) = 0;
uniform float emission_fresnel_power : hint_range(0.5, 8.0) = 3.0;
uniform sampler2D emission_texture : hint_default_white;
uniform float emission_texture_strength : hint_range(0.0, 1.0) = 1.0;

// Pulsação da emissão
uniform bool emission_pulse = false;
uniform float pulse_speed : hint_range(0.1, 10.0) = 2.0;
uniform float pulse_intensity : hint_range(0.0, 1.0) = 0.4; // quanto oscila (0 = sem oscilação)

varying vec3 world_normal;

void vertex() {
    world_normal = normalize((MODEL_MATRIX * vec4(NORMAL, 0.0)).xyz);
}

float fresnel_schlick(float cos_theta, float f0, float power) {
    return f0 + (1.0 - f0) * pow(clamp(1.0 - cos_theta, 0.0, 1.0), power);
}

void fragment() {
    // --- Normal ---
    vec3 N = normalize(world_normal);
    if (use_normal_map) {
        vec3 nm = texture(normal_map_tex, UV).rgb * 2.0 - 1.0;
        N = normalize(N + nm * normal_map_strength);
    }

    vec3 V = normalize(VIEW);
    float NdotV = max(dot(N, V), 0.0);

    // --- Fresnel principal ---
    float f0 = pow((ior - 1.0) / (ior + 1.0), 2.0);
    float fresnel = fresnel_schlick(NdotV, f0, fresnel_power) * fresnel_intensity;

    // --- Refração ---
    vec3 refract_dir = refract(-V, N, 1.0 / ior);
    vec2 refract_offset = refract_dir.xy * refraction_strength * (1.0 - roughness);
    float mip_level = blur_amount * 6.0;

    vec2 uv_r = SCREEN_UV + refract_offset * (1.0 + chromatic_aberration);
    vec2 uv_g = SCREEN_UV + refract_offset;
    vec2 uv_b = SCREEN_UV + refract_offset * (1.0 - chromatic_aberration);

    vec3 scene_color = vec3(
        textureLod(screen_texture, uv_r, mip_level).r,
        textureLod(screen_texture, uv_g, mip_level).g,
        textureLod(screen_texture, uv_b, mip_level).b
    );

    // --- Absorção Beer-Lambert ---
    if (absorption_density > 0.0) {
        float depth_raw = texture(depth_texture, SCREEN_UV).r;
        vec3 ndc = vec3(SCREEN_UV * 2.0 - 1.0, depth_raw);
        vec4 view_space = INV_PROJECTION_MATRIX * vec4(ndc, 1.0);
        view_space /= view_space.w;
        float thickness = max(-view_space.z - length(VIEW), 0.0);
        scene_color *= exp(-absorption_density * thickness * (1.0 - absorption_color.rgb));
    }

    // --- Cor final do vidro ---
    ALBEDO = mix(scene_color, scene_color * glass_tint.rgb, transparency);
    METALLIC = metallic;
    ROUGHNESS = roughness;
    SPECULAR = specular_strength;
    ALPHA = clamp(transparency + fresnel * 1.0, 0.0, 1.0);

    if (use_normal_map) {
        NORMAL_MAP = texture(normal_map_tex, UV).rgb;
        NORMAL_MAP_DEPTH = normal_map_strength;
    }

    // --- Emissão ---
    if (use_emission) {
        // Padrão espacial
        float pattern_mask = 1.0;
        if (emission_pattern == 1) {
            // Fresnel: brilha nas bordas (efeito neon/holo)
            pattern_mask = fresnel_schlick(NdotV, 0.0, emission_fresnel_power);
        } else if (emission_pattern == 2) {
            // Núcleo: brilha no centro (efeito plasma/magma)
            pattern_mask = 1.0 - fresnel_schlick(NdotV, 0.0, emission_fresnel_power);
        } else if (emission_pattern == 3) {
            // Textura
            pattern_mask = texture(emission_texture, UV).r * emission_texture_strength;
        }

        // Pulsação no tempo
        float pulse = 1.0;
        if (emission_pulse) {
            pulse = 1.0 - pulse_intensity + pulse_intensity * (sin(TIME * pulse_speed) * 0.5 + 0.5);
        }

        EMISSION = emission_color.rgb * emission_energy * pattern_mask * pulse;
    }
}"

