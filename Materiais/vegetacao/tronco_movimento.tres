[sub_resource type="Shader" id="Shader_jm5f2"]
code = "shader_type spatial;
render_mode depth_draw_opaque, cull_disabled;

// --- Configurações do Vento ---
group_uniforms Vento;
uniform float wind_speed : hint_range(0.0, 5.0) = 1.0; 
uniform float wind_strength : hint_range(0.0, 1.0) = 0.1; 
uniform vec2 wind_direction = vec2(1.0, 0.5); 

// --- Configurações Visuais ---
group_uniforms Texturas;
uniform vec4 albedo_color : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap_anisotropic;

uniform sampler2D texture_normal : hint_normal, filter_linear_mipmap_anisotropic;
uniform float normal_scale : hint_range(-16.0, 16.0) = 1.0;

// --- Configurações do Height/Parallax (Aprimorado) ---
group_uniforms Parallax;
uniform sampler2D texture_height : hint_default_black, filter_linear_mipmap_anisotropic;
uniform float height_scale : hint_range(0.0, 0.2) = 0.05; // Intensidade da profundidade
uniform bool invert_height = false; // Útil se o branco for fundo e o preto for o topo
uniform int min_layers : hint_range(1, 64) = 8;  // Camadas vistas olhando de frente
uniform int max_layers : hint_range(1, 64) = 32; // Camadas vistas olhando de lado

// --- Material Base ---
group_uniforms Material;
uniform float roughness : hint_range(0.0, 1.0) = 1.0;
uniform float specular : hint_range(0.0, 1.0) = 0.5;
uniform float alpha_scissor_threshold : hint_range(0.0, 1.0) = 0.5;

float get_hash(vec2 pos) {
	return fract(sin(dot(pos, vec2(12.9898, 78.233))) * 43758.5453);
}

void vertex() {
	vec3 world_pos = MODEL_MATRIX[3].xyz;
	float time_offset = get_hash(world_pos.xz);
	
	float height = max(0.0, VERTEX.y);
	float bend_factor = pow(height, 2.0);

	float time = TIME * wind_speed + time_offset;
	float movement = sin(time) + (sin(time * 2.5) * 0.2); 
	
	vec2 dir = normalize(wind_direction);
	
	VERTEX.x += movement * wind_strength * bend_factor * dir.x;
	VERTEX.z += movement * wind_strength * bend_factor * dir.y;
}

void fragment() {
	vec2 base_uv = UV;
	
	// --- Parallax Occlusion Mapping (POM) ---
	// Calcula a direção da visão (câmera) no Tangent Space
	vec3 view_dir_ts = normalize(VIEW * mat3(TANGENT, BINORMAL, NORMAL));
	
	// Ajusta dinamicamente as camadas: ângulos rasos precisam de mais fatias
	float num_layers = mix(float(max_layers), float(min_layers), abs(view_dir_ts.z));
	float layer_depth = 1.0 / num_layers;
	float current_layer_depth = 0.0;
	
	// Passo de deslocamento UV
	vec2 p = view_dir_ts.xy * (height_scale / num_layers);
	vec2 current_uv = base_uv;
	
	// Leitura inicial da altura
	float current_height = texture(texture_height, current_uv).r;
	if (invert_height) current_height = 1.0 - current_height;

	// Loop do Raymarching: Avança fatiando a textura de profundidade até cruzar a superfície
	for (int i = 0; i < int(max_layers); i++) {
		if (current_layer_depth >= current_height) {
			break;
		}
		current_uv -= p;
		current_height = texture(texture_height, current_uv).r;
		if (invert_height) current_height = 1.0 - current_height;
		
		current_layer_depth += layer_depth;
	}
	
	// Interpolação para suavizar o efeito degrau (Steep Parallax para Parallax Occlusion)
	vec2 prev_uv = current_uv + p;
	float next_depth = current_height - current_layer_depth;
	
	float prev_height = texture(texture_height, prev_uv).r;
	if (invert_height) prev_height = 1.0 - prev_height;
	float prev_depth = prev_height - current_layer_depth + layer_depth;
	
	float weight = next_depth / (next_depth - prev_depth);
	base_uv = mix(current_uv, prev_uv, weight);
	// ----------------------------------------

	// --- Aplica o novo UV modificado nas outras texturas ---
	vec4 albedo_tex = texture(texture_albedo, base_uv);
	vec3 normal_tex = texture(texture_normal, base_uv).rgb;

	// Multiplica a cor da textura pela cor definida no inspetor
	ALBEDO = albedo_tex.rgb * albedo_color.rgb;
	
	NORMAL_MAP = normal_tex;
	NORMAL_MAP_DEPTH = normal_scale;

	ROUGHNESS = roughness;
	SPECULAR = specular;

	ALPHA = albedo_tex.a * albedo_color.a;
	ALPHA_SCISSOR_THRESHOLD = alpha_scissor_threshold;
}"

[resource]
render_priority = 0
shader = SubResource("Shader_jm5f2")
shader_parameter/wind_speed = 1.0
shader_parameter/wind_strength = 0.0
shader_parameter/wind_direction = Vector2(1, 0.5)
shader_parameter/albedo_color = Color(0.53515625, 0.37628174, 0, 1)
shader_parameter/texture_albedo = ExtResource("1_6wo7e")
shader_parameter/texture_normal = ExtResource("2_6wo7e")
shader_parameter/normal_scale = 2.9100008982250003
shader_parameter/texture_height = ExtResource("2_6xma7")
shader_parameter/height_scale = 0.0210000009975
shader_parameter/invert_height = false
shader_parameter/min_layers = 8
shader_parameter/max_layers = 32
shader_parameter/roughness = 1.0
shader_parameter/specular = 0.5
shader_parameter/alpha_scissor_threshold = 0.5
