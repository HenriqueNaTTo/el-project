code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D tex_vtx_5;
uniform vec4 ColorParameter : source_color = vec4(0.000000, 0.126219, 0.253906, 1.000000);
uniform sampler2D tex_frg_3;
uniform sampler2D tex_frg_9;
uniform sampler2D tex_frg_15;
uniform sampler2D tex_frg_20;



void vertex() {
// Input:2
	float n_out2p0 = TIME;


// UVFunc:3
	vec2 n_in3p1 = vec2(0.10000, 0.10000);
	vec2 n_out3p0 = vec2(n_out2p0) * n_in3p1 + UV;


// Texture2D:5
	vec4 n_out5p0 = texture(tex_vtx_5, n_out3p0);


// Input:6
	vec3 n_out6p0 = VERTEX;


// VectorOp:9
	vec4 n_in9p1 = vec4(0.80000, 0.80000, 0.80000, 0.80000);
	vec4 n_out9p0 = vec4(n_out6p0, 0.0) * n_in9p1;


// Input:7
	vec3 n_out7p0 = VERTEX;


// MultiplyAdd:8
	vec4 n_out8p0 = fma(n_out5p0, n_out9p0, vec4(n_out7p0, 0.0));


// Output:0
	VERTEX = vec3(n_out8p0.xyz);


}

void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = ColorParameter;


// Input:6
	float n_out6p0 = TIME;


// UVFunc:5
	vec2 n_in5p1 = vec2(0.05000, 0.05000);
	vec2 n_out5p0 = vec2(n_out6p0) * n_in5p1 + UV;


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, n_out5p0);


// Input:8
	float n_out8p0 = TIME;


// UVFunc:7
	vec2 n_in7p1 = vec2(-0.05000, -0.05000);
	vec2 n_out7p0 = vec2(n_out8p0) * n_in7p1 + UV;


// Texture2D:9
	vec4 n_out9p0 = texture(tex_frg_9, n_out7p0);


// VectorOp:10
	vec4 n_out10p0 = n_out3p0 * n_out9p0;


// VectorOp:11
	vec4 n_in11p1 = vec4(1.00000, 1.00000, 1.00000, 1.00000);
	vec4 n_out11p0 = pow(n_out10p0, n_in11p1);


// VectorOp:4
	vec4 n_out4p0 = n_out2p0 + n_out11p0;


// FloatConstant:12
	float n_out12p0 = 0.600000;


// FloatConstant:14
	float n_out14p0 = 0.100000;


// FloatConstant:13
	float n_out13p0 = 0.600000;


// Input:17
	float n_out17p0 = TIME;


// UVFunc:16
	vec2 n_in16p1 = vec2(0.05000, 0.05000);
	vec2 n_out16p0 = vec2(n_out17p0) * n_in16p1 + UV;


// Texture2D:15
	vec4 n_out15p0 = texture(tex_frg_15, n_out16p0);


// Input:19
	float n_out19p0 = TIME;


// UVFunc:18
	vec2 n_in18p1 = vec2(-0.05000, -0.05000);
	vec2 n_out18p0 = vec2(n_out19p0) * n_in18p1 + UV;


// Texture2D:20
	vec4 n_out20p0 = texture(tex_frg_20, n_out18p0);


// VectorOp:21
	vec4 n_out21p0 = n_out15p0 * n_out20p0;


// VectorOp:22
	vec4 n_in22p1 = vec4(1.00000, 1.00000, 1.00000, 1.00000);
	vec4 n_out22p0 = pow(n_out21p0, n_in22p1);


// Output:0
	ALBEDO = vec3(n_out4p0.xyz);
	ALPHA = n_out12p0;
	ROUGHNESS = n_out14p0;
	SPECULAR = n_out13p0;
	NORMAL = vec3(n_out22p0.xyz);


}
