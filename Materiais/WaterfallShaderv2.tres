[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform vec4 ColorParameter : source_color = vec4(0.000000, 0.201172, 0.402344, 1.000000);
uniform sampler2D tex_frg_3;
uniform sampler2D tex_frg_7;
uniform sampler2D depth_tex_frg_14 : hint_depth_texture;
uniform sampler2D tex_frg_31;
uniform sampler2D tex_frg_28;



void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = ColorParameter;


// Input:6
	float n_out6p0 = TIME;


// UVFunc:5
	vec2 n_in5p1 = vec2(0.00000, -0.50000);
	vec2 n_out5p0 = vec2(n_out6p0) * n_in5p1 + UV;


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, n_out5p0);


// Input:8
	float n_out8p0 = TIME;


// UVFunc:9
	vec2 n_in9p1 = vec2(0.00000, -0.40000);
	vec2 n_out9p0 = vec2(n_out8p0) * n_in9p1 + UV;


// Texture2D:7
	vec4 n_out7p0 = texture(tex_frg_7, n_out9p0);


// VectorOp:4
	vec3 n_out4p0 = vec3(n_out3p0.xyz) * vec3(n_out7p0.xyz);


// FloatOp:11
	float n_in11p1 = 1.50000;
	float n_out11p0 = pow(n_out4p0.x, n_in11p1);


// VectorOp:10
	vec3 n_out10p0 = vec3(n_out2p0.xyz) + vec3(n_out11p0);


// Input:17
	float n_out17p0 = TIME;


	float n_out14p0;
// ProximityFade:14
	float n_in14p0 = 1.00000;
	{
		float __depth_tex = texture(depth_tex_frg_14, SCREEN_UV).r;
		vec4 __depth_world_pos = INV_PROJECTION_MATRIX * vec4(SCREEN_UV * 2.0 - 1.0, __depth_tex, 1.0);
		__depth_world_pos.xyz /= __depth_world_pos.w;
		n_out14p0 = clamp(1.0 - smoothstep(__depth_world_pos.z + n_in14p0, __depth_world_pos.z, VERTEX.z), 0.0, 1.0);
	}


// FloatFunc:15
	float n_out15p0 = 1.0 - n_out14p0;


// MultiplyAdd:23
	float n_in23p1 = 0.50000;
	float n_out23p0 = fma(n_out17p0, n_in23p1, n_out15p0);


// FloatOp:22
	float n_in22p1 = 1.00000;
	float n_out22p0 = n_out23p0 * n_in22p1;


// FloatFunc:16
	float n_out16p0 = sin(n_out22p0);


// FloatFunc:18
	float n_out18p0 = abs(n_out16p0);


// FloatOp:19
	float n_out19p0 = n_out18p0 * n_out15p0;


// FloatOp:20
	float n_in20p1 = 24.00000;
	float n_out20p0 = pow(n_out15p0, n_in20p1);


// FloatOp:21
	float n_out21p0 = n_out19p0 + n_out20p0;


// Mix:24
	vec3 n_in24p2 = vec3(0.50000, 0.50000, 0.50000);
	vec3 n_out24p0 = mix(n_out10p0, vec3(n_out21p0), n_in24p2);


// FloatConstant:12
	float n_out12p0 = 0.900000;


// FloatConstant:13
	float n_out13p0 = 0.200000;


// FloatConstant:25
	float n_out25p0 = 1.000000;


// Input:32
	float n_out32p0 = TIME;


// UVFunc:27
	vec2 n_in27p1 = vec2(0.00000, -0.50000);
	vec2 n_out27p0 = vec2(n_out32p0) * n_in27p1 + UV;


// Texture2D:31
	vec4 n_out31p0 = texture(tex_frg_31, n_out27p0);


// Input:29
	float n_out29p0 = TIME;


// UVFunc:30
	vec2 n_in30p1 = vec2(0.00000, -0.40000);
	vec2 n_out30p0 = vec2(n_out29p0) * n_in30p1 + UV;


// Texture2D:28
	vec4 n_out28p0 = texture(tex_frg_28, n_out30p0);


// VectorOp:26
	vec3 n_out26p0 = vec3(n_out31p0.xyz) * vec3(n_out28p0.xyz);


// FloatOp:33
	float n_in33p1 = 1.00000;
	float n_out33p0 = pow(n_out26p0.x, n_in33p1);


// Output:0
	ALBEDO = n_out24p0;
	ALPHA = n_out12p0;
	ROUGHNESS = n_out13p0;
	SPECULAR = n_out25p0;
	EMISSION = vec3(n_out11p0);
	NORMAL_MAP = vec3(n_out33p0);


}
