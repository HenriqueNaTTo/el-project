[sub_resource type="Shader" id="Shader_2eaaf"]
code = "shader_type spatial;
render_mode blend_mix, depth_prepass_alpha, cull_disabled;

// --- CONFIGURAÇÕES GERAIS ---
group_uniforms Base_Material;
uniform vec4 base_color_tint : source_color = vec4(1.0, 1.0, 1.0, 1.0); // NOVA COR
uniform sampler2D base_albedo : source_color, filter_linear_mipmap;
uniform sampler2D base_normal : hint_normal, filter_linear_mipmap;
uniform sampler2D base_roughness : hint_default_white, filter_linear_mipmap;
uniform float base_uv_scale = 1.0;

group_uniforms Overlay_Material;
uniform vec4 overlay_color_tint : source_color = vec4(1.0, 1.0, 1.0, 1.0); // NOVA COR
uniform sampler2D overlay_albedo : source_color, filter_linear_mipmap;
uniform sampler2D overlay_normal : hint_normal, filter_linear_mipmap;
uniform sampler2D overlay_roughness : hint_default_white, filter_linear_mipmap;
uniform float overlay_uv_scale = 1.0;

group_uniforms Masking;
uniform sampler2D noise_texture : hint_default_white, filter_linear_mipmap; 
uniform float noise_scale = 1.0;
uniform float blend_sharpness : hint_range(0.0, 1.0) = 0.5;

group_uniforms Logic_Contact;
uniform bool use_contact = true;
uniform float contact_distance : hint_range(0.0, 2.0) = 0.5;
uniform float contact_intensity : hint_range(0.0, 5.0) = 1.0;
uniform sampler2D DEPTH_TEXTURE : hint_depth_texture, filter_linear_mipmap;

group_uniforms Logic_Top;
uniform bool use_top = true;
uniform float top_threshold : hint_range(-1.0, 1.0) = 0.5;
uniform float top_softness : hint_range(0.0, 1.0) = 0.2;

// --- VARIÁVEIS PARA COMUNICAÇÃO VERTEX -> FRAGMENT ---
varying vec3 world_pos;
varying vec3 world_normal;

// --- FUNÇÕES ---

void vertex() {
	// Calcula a posição e normal do vértice no mundo real (evita \"nadar\" a textura)
	world_pos = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz;
	world_normal = (MODEL_MATRIX * vec4(NORMAL, 0.0)).xyz;
}

vec4 triplanar_texture(sampler2D p_sampler, vec3 p_weights, vec3 p_triplanar_pos) {
	vec4 samp = vec4(0.0);
	samp += texture(p_sampler, p_triplanar_pos.xy) * p_weights.z;
	samp += texture(p_sampler, p_triplanar_pos.xz) * p_weights.y;
	samp += texture(p_sampler, p_triplanar_pos.zy * vec2(-1.0, 1.0)) * p_weights.x;
	return samp;
}

void fragment() {
	// 1. Pesos Triplanares Baseados no Mundo
	vec3 w_norm = normalize(world_normal);
	vec3 triplanar_weights = abs(w_norm);
	triplanar_weights /= (triplanar_weights.x + triplanar_weights.y + triplanar_weights.z);

	// 2. Coordenadas Triplanares Baseadas no Mundo
	vec3 triplanar_pos_base = world_pos * base_uv_scale;
	vec3 triplanar_pos_overlay = world_pos * overlay_uv_scale;

	// 3. Ler Texturas e APLICAR A COR
	vec3 col_base = triplanar_texture(base_albedo, triplanar_weights, triplanar_pos_base).rgb;
	col_base *= base_color_tint.rgb; // Multiplica pela cor base

	vec3 col_over = triplanar_texture(overlay_albedo, triplanar_weights, triplanar_pos_overlay).rgb;
	col_over *= overlay_color_tint.rgb; // Multiplica pela cor do musgo/overlay
	
	vec3 norm_base = triplanar_texture(base_normal, triplanar_weights, triplanar_pos_base).rgb;
	float rgh_base = triplanar_texture(base_roughness, triplanar_weights, triplanar_pos_base).r;

	vec3 norm_over = triplanar_texture(overlay_normal, triplanar_weights, triplanar_pos_overlay).rgb;
	float rgh_over = triplanar_texture(overlay_roughness, triplanar_weights, triplanar_pos_overlay).r;
	
	float noise = triplanar_texture(noise_texture, triplanar_weights, world_pos * noise_scale).r;

	// --- LÓGICA DE MISTURA ---
	float final_mask = 0.0;

	if (use_contact) {
		float depth = texture(DEPTH_TEXTURE, SCREEN_UV).x;
		vec3 ndc = vec3(SCREEN_UV * 2.0 - 1.0, depth);
		vec4 view = INV_PROJECTION_MATRIX * vec4(ndc, 1.0);
		view.xyz /= view.w;
		float linear_depth = -view.z;
		
		float object_depth = -VERTEX.z; 
		float depth_diff = linear_depth - object_depth;
		float contact_mask = 1.0 - smoothstep(0.0, contact_distance, depth_diff);
		
		final_mask = max(final_mask, contact_mask * contact_intensity);
	}

	if (use_top) {
		float top_dot = dot(w_norm, vec3(0.0, 1.0, 0.0));
		float top_mask = smoothstep(top_threshold - top_softness, top_threshold + top_softness, top_dot);
		final_mask = max(final_mask, top_mask);
	}

	float noise_blend = smoothstep(1.0 - final_mask - blend_sharpness, 1.0 - final_mask + blend_sharpness, noise);
	float mix_factor = clamp(noise_blend, 0.0, 1.0);

	// Mistura Final
	ALBEDO = mix(col_base, col_over, mix_factor);
	ROUGHNESS = mix(rgh_base, rgh_over, mix_factor);
	NORMAL_MAP = mix(norm_base, norm_over, mix_factor);
}"

