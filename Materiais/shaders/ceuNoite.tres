[gd_resource type="Sky" load_steps=9 format=3 uid="uid://bqyg3x2m3u2d0"]

[sub_resource type="Shader" id="Shader_rr1lg"]
code = "shader_type sky;
render_mode use_half_res_pass;

uniform float rayleigh : hint_range(0, 64) = 2.0;
uniform vec4 rayleigh_color : source_color = vec4(0.3, 0.405, 0.6, 1.0);
uniform float mie : hint_range(0, 1) = 0.005;
uniform float mie_eccentricity : hint_range(-1, 1) = 0.8;
uniform vec4 mie_color : source_color = vec4(0.69, 0.729, 0.812, 1.0);

uniform float turbidity : hint_range(0, 1000) = 10.0;
uniform float sun_disk_scale : hint_range(0, 360) = 1.0;
uniform vec4 ground_color : source_color = vec4(0.1, 0.07, 0.034, 1.0);
uniform float exposure : hint_range(0, 128) = 1.0;

uniform sampler2D night_sky : filter_nearest, source_color, hint_default_black;
uniform sampler2D stars_texture : filter_nearest, source_color, hint_default_black;

uniform float move_speed : hint_range(0.0, 5.0) = 0.1;

uniform float sun_glow_strength : hint_range(0.0, 5.0) = 1.5;
uniform float sun_glow_falloff : hint_range(0.1, 10.0) = 2.5;

uniform sampler2D cloud_texture : source_color, hint_default_white;
uniform float cloud_coverage : hint_range(0.0, 1.0) = 0.5;
uniform float cloud_opacity : hint_range(0.0, 1.0) = 0.4;
uniform float cloud_scale : hint_range(0.1, 10.0) = 1.0;
uniform float cloud_movement_speed_multiplier : hint_range(0.0, 2.0) = 0.2; // Added uniform for cloud movement speed

const vec3 UP = vec3(0.0, 1.0, 0.0);
const float rayleigh_zenith_size = 8.4e3;
const float mie_zenith_size = 1.25e3;

float henyey_greenstein(float cos_theta, float g) {
    const float k = 0.0795774715459;
    return k * (1.0 - g * g) / (pow(1.0 + g * g - 2.0 * g * cos_theta, 1.5));
}

void sky() {
    vec2 sky_coords = SKY_COORDS.xy;
    vec2 animated_coords = sky_coords + vec2(TIME * move_speed, 0.0);

    if (LIGHT0_ENABLED) {
        float zenith_angle = clamp(dot(UP, normalize(LIGHT0_DIRECTION)), -1.0, 1.0);
        float sun_energy = max(0.0, 1.0 - exp(-((PI * 0.5) - acos(zenith_angle)))) * LIGHT0_ENERGY;
        float sun_fade = 1.0 - clamp(1.0 - exp(LIGHT0_DIRECTION.y), 0.0, 1.0);

        float rayleigh_coefficient = rayleigh - (1.0 * (1.0 - sun_fade));
        vec3 rayleigh_beta = rayleigh_coefficient * rayleigh_color.rgb * 0.0001;
        vec3 mie_beta = turbidity * mie * mie_color.rgb * 0.000434;

        float zenith = acos(max(0.0, dot(UP, EYEDIR)));
        float optical_mass = 1.0 / (cos(zenith) + 0.15 * pow(93.885 - degrees(zenith), -1.253));
        float rayleigh_scatter = rayleigh_zenith_size * optical_mass;
        float mie_scatter = mie_zenith_size * optical_mass;

        vec3 extinction = exp(-(rayleigh_beta * rayleigh_scatter + mie_beta * mie_scatter));

        float cos_theta = dot(EYEDIR, normalize(LIGHT0_DIRECTION));
        float rayleigh_phase = (3.0 / (16.0 * PI)) * (1.0 + pow(cos_theta * 0.5 + 0.5, 2.0));
        vec3 betaRTheta = rayleigh_beta * rayleigh_phase;

        float mie_phase = henyey_greenstein(cos_theta, mie_eccentricity);
        vec3 betaMTheta = mie_beta * mie_phase;

        vec3 Lin = pow(sun_energy * ((betaRTheta + betaMTheta) / (rayleigh_beta + mie_beta)) * (1.0 - extinction), vec3(1.5));
        Lin *= mix(vec3(1.0), pow(sun_energy * ((betaRTheta + betaMTheta) / (rayleigh_beta + mie_beta)) * extinction, vec3(0.5)), clamp(pow(1.0 - zenith_angle, 5.0), 0.0, 1.0));
        Lin *= mix(ground_color.rgb, vec3(1.0), smoothstep(-0.1, 0.1, dot(UP, EYEDIR)));

        // Sol + glow
        float sunAngularDiameterCos = cos(LIGHT0_SIZE * sun_disk_scale);
        float sunAngularDiameterCos2 = cos(LIGHT0_SIZE * sun_disk_scale * 0.5);
        float sundisk = smoothstep(sunAngularDiameterCos, sunAngularDiameterCos2, cos_theta);
        float glow = pow(max(cos_theta, 0.0), sun_glow_falloff) * sun_glow_strength;
        vec3 sun_contrib = (sun_energy * extinction) * (sundisk + glow) * LIGHT0_COLOR;

        // Céu noturno + estrelas
        vec3 night = texture(night_sky, animated_coords).xyz * extinction;
        vec3 stars = texture(stars_texture, animated_coords).xyz * (1.0 - extinction);
        vec3 L0 = sun_contrib + night + stars;

        // Nuvens - Adicionada movimentação aqui
        vec2 cloud_coords = SKY_COORDS.xy * cloud_scale + vec2(TIME * move_speed * cloud_movement_speed_multiplier, 0.0);
        float cloud_sample = texture(cloud_texture, cloud_coords).r;
        float cloud_mask = smoothstep(cloud_coverage - 0.1, cloud_coverage + 0.1, cloud_sample);
        vec3 cloud_color = mix(vec3(0.0), vec3(1.0), cloud_mask) * cloud_opacity;

        vec3 color = Lin + L0;
        color = mix(color, vec3(1.0), cloud_mask * cloud_opacity); // aplica nuvem
        COLOR = pow(color, vec3(1.0 / (1.2 + (1.2 * sun_fade))));
        COLOR *= exposure;
    } else {
        // Céu noturno puro
        vec3 night = texture(night_sky, animated_coords).rgb;
        vec3 stars = texture(stars_texture, animated_coords).xyz;
        vec3 base = night + stars;

        // Nuvens - Adicionada movimentação aqui
        vec2 cloud_coords = SKY_COORDS.xy * cloud_scale + vec2(TIME * move_speed * cloud_movement_speed_multiplier, 0.0);
        float cloud_sample = texture(cloud_texture, cloud_coords).r;
        float cloud_mask = smoothstep(cloud_coverage - 0.1, cloud_coverage + 0.1, cloud_sample);
        vec3 color = mix(base, vec3(1.0), cloud_mask * cloud_opacity);

        COLOR = color * exposure;
    }
}"

