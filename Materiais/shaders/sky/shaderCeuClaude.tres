[gd_resource type="Shader" format=3 uid="uid://b4njsteqptpnq"]

[resource]
code = "shader_type sky;

// === PARÂMETROS PRINCIPAIS ===
uniform float time_of_day : hint_range(0.0, 1.0) = 0.5;
uniform float cloud_density : hint_range(0.0, 1.0) = 0.5;
uniform float cloud_speed : hint_range(0.0, 2.0) = 0.5;
uniform float cloud_scale : hint_range(0.1, 5.0) = 1.5;
uniform float atmosphere_thickness : hint_range(0.5, 3.0) = 1.2;

// === CONFIGURAÇÕES DO SOL ===
uniform float sun_intensity : hint_range(0.0, 10.0) = 3.0;
uniform float sun_size : hint_range(0.01, 0.2) = 0.08;
uniform vec3 sun_color : source_color = vec3(1.0, 0.95, 0.8);
uniform sampler2D sun_texture : source_color, hint_default_white;
uniform bool use_sun_texture;

// === CONFIGURAÇÕES DA LUA ===
uniform float moon_intensity : hint_range(0.0, 5.0) = 1.0;
uniform float moon_size : hint_range(0.01, 0.15) = 0.06;
uniform vec3 moon_color : source_color = vec3(0.9, 0.9, 1.0);
uniform sampler2D moon_texture : source_color, hint_default_white;
uniform bool use_moon_texture;

// === CORES DO CÉU ===
uniform vec3 day_horizon_color : source_color = vec3(0.8, 0.9, 1.0);
uniform vec3 day_zenith_color : source_color = vec3(0.4, 0.7, 1.0);
uniform vec3 night_horizon_color : source_color = vec3(0.1, 0.1, 0.2);
uniform vec3 night_zenith_color : source_color = vec3(0.02, 0.02, 0.1);
uniform vec3 sunset_color : source_color = vec3(1.0, 0.4, 0.1);
uniform vec3 sunrise_color : source_color = vec3(1.0, 0.6, 0.3);

// === PARÂMETROS DAS NUVENS ===
uniform float cloud_coverage : hint_range(0.0, 1.0) = 0.4;
uniform float cloud_sharpness : hint_range(0.1, 10.0) = 3.0;
uniform float cloud_thickness : hint_range(0.1, 2.0) = 1.0;
uniform vec3 cloud_color : source_color = vec3(1.0, 1.0, 1.0);
uniform vec3 cloud_shadow_color : source_color = vec3(0.4, 0.4, 0.5);
uniform sampler2D cloud_texture : source_color, hint_default_white;
uniform float cloud_texture_scale : hint_range(0.1, 5.0) = 1.0;

// === CONFIGURAÇÕES DAS ESTRELAS ===
uniform sampler2D star_texture : source_color, hint_default_white;
uniform float star_texture_scale : hint_range(0.1, 10.0) = 2.0;
uniform float star_brightness : hint_range(0.0, 3.0) = 1.5;
uniform float star_twinkle_speed : hint_range(0.0, 5.0) = 2.0;

// === FUNÇÕES DE RUÍDO MELHORADAS ===
float hash21(vec2 p) {
    return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);
}

float hash31(vec3 p) {
    return fract(sin(dot(p, vec3(127.1, 311.7, 74.7))) * 43758.5453123);
}

vec2 hash22(vec2 p) {
    p = vec2(dot(p, vec2(127.1, 311.7)), dot(p, vec2(269.5, 183.3)));
    return fract(sin(p) * 43758.5453123);
}

float noise21(vec2 p) {
    vec2 i = floor(p);
    vec2 f = fract(p);
    
    float a = hash21(i);
    float b = hash21(i + vec2(1.0, 0.0));
    float c = hash21(i + vec2(0.0, 1.0));
    float d = hash21(i + vec2(1.0, 1.0));
    
    vec2 u = f * f * (3.0 - 2.0 * f);
    
    return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
}

float noise31(vec3 p) {
    vec3 i = floor(p);
    vec3 f = fract(p);
    
    float a = hash31(i);
    float b = hash31(i + vec3(1.0, 0.0, 0.0));
    float c = hash31(i + vec3(0.0, 1.0, 0.0));
    float d = hash31(i + vec3(1.0, 1.0, 0.0));
    float e = hash31(i + vec3(0.0, 0.0, 1.0));
    float f1 = hash31(i + vec3(1.0, 0.0, 1.0));
    float g = hash31(i + vec3(0.0, 1.0, 1.0));
    float h = hash31(i + vec3(1.0, 1.0, 1.0));
    
    vec3 u = f * f * (3.0 - 2.0 * f);
    
    return mix(mix(mix(a, b, u.x), mix(c, d, u.x), u.y),
               mix(mix(e, f1, u.x), mix(g, h, u.x), u.y), u.z);
}

// === RUÍDO FRACTAL MELHORADO ===
float fbm2(vec2 p, int octaves, float persistence, float lacunarity) {
    float value = 0.0;
    float amplitude = 0.5;
    float frequency = 1.0;
    float max_value = 0.0;
    
    for (int i = 0; i < octaves; i++) {
        value += amplitude * noise21(p * frequency);
        max_value += amplitude;
        amplitude *= persistence;
        frequency *= lacunarity;
    }
    
    return value / max_value;
}

float fbm3(vec3 p, int octaves, float persistence, float lacunarity) {
    float value = 0.0;
    float amplitude = 0.5;
    float frequency = 1.0;
    float max_value = 0.0;
    
    for (int i = 0; i < octaves; i++) {
        value += amplitude * noise31(p * frequency);
        max_value += amplitude;
        amplitude *= persistence;
        frequency *= lacunarity;
    }
    
    return value / max_value;
}

// === ESPALHAMENTO ATMOSFÉRICO MELHORADO ===
vec3 atmospheric_scattering(vec3 view_dir, vec3 light_dir, float thickness) {
    float cosine = dot(view_dir, light_dir);
    float g = 0.76; // Parâmetro de fase Mie
    
    // Fase de Mie
    float mie_phase = (1.0 - g * g) / pow(1.0 + g * g - 2.0 * g * cosine, 1.5);
    
    // Fase de Rayleigh
    float rayleigh_phase = 0.75 * (1.0 + cosine * cosine);
    
    // Cores do espalhamento
    vec3 rayleigh_color = vec3(0.23, 0.55, 1.0);
    vec3 mie_color = vec3(1.0, 0.9, 0.7);
    
    // Densidade atmosférica baseada na altura
    float density = exp(-max(0.0, view_dir.y) * thickness);
    
    // Combinação dos efeitos
    vec3 scatter = mix(rayleigh_color * rayleigh_phase, mie_color * mie_phase, 0.1);
    
    return scatter * density;
}

// === COR DO CÉU COM CICLO COMPLETO ===
vec3 get_sky_color(vec3 view_dir, float time) {
    float elevation = clamp(view_dir.y, -1.0, 1.0);
    float sun_angle = time * 2.0 * PI;
    float sun_height = sin(sun_angle);
    
    // Cores base
    vec3 day_color = mix(day_horizon_color, day_zenith_color, 
                        smoothstep(-0.1, 0.6, elevation));
    vec3 night_color = mix(night_horizon_color, night_zenith_color, 
                          smoothstep(-0.1, 0.8, elevation));
    
    // Efeito do pôr/nascer do sol
    float horizon_factor = 1.0 - abs(elevation);
    float sunrise_factor = smoothstep(-0.3, 0.1, sun_height) * 
                          smoothstep(0.4, 0.1, sun_height) * 
                          smoothstep(0.8, 0.2, horizon_factor);
    
    float sunset_factor = smoothstep(-0.1, -0.4, sun_height) * 
                         smoothstep(-0.7, -0.4, sun_height) * 
                         smoothstep(0.8, 0.2, horizon_factor);
    
    // Aplicação das cores de transição
    vec3 color = day_color;
    color = mix(color, sunrise_color, sunrise_factor);
    color = mix(color, sunset_color, sunset_factor);
    
    // Transição dia/noite
    float day_factor = smoothstep(-0.2, 0.2, sun_height);
    return mix(night_color, color, day_factor);
}

// === PROJEÇÃO ESFÉRICA PARA TEXTURAS ===
vec2 sphere_project(vec3 dir) {
    float u = 0.5 + atan(dir.z, dir.x) / (2.0 * PI);
    float v = 0.5 - asin(dir.y) / PI;
    return vec2(u, v);
}

// === CÁLCULO DAS NUVENS MELHORADO ===
float get_cloud_density(vec3 view_dir, float time) {
    if (view_dir.y < -0.05) return 0.0;
    
    // Animação das nuvens
    vec3 wind_offset = vec3(time * cloud_speed * 0.02, 0.0, time * cloud_speed * 0.01);
    vec3 cloud_pos = view_dir * cloud_scale + wind_offset;
    
    // Múltiplas camadas de ruído
    float cloud_base = fbm3(cloud_pos, 6, 0.5, 2.0);
    float cloud_detail = fbm3(cloud_pos * 3.0, 4, 0.4, 2.2);
    float cloud_wispy = fbm3(cloud_pos * 8.0, 3, 0.3, 2.5);
    
    // Combinação das camadas
    float combined_noise = cloud_base * 0.6 + cloud_detail * 0.3 + cloud_wispy * 0.1;
    
    // Textura das nuvens se disponível
    vec2 cloud_uv = sphere_project(view_dir);
    cloud_uv = fract(cloud_uv * cloud_texture_scale + wind_offset.xz * 0.1);
    float cloud_tex = texture(cloud_texture, cloud_uv).r;
    
    // Combinação final
    float final_cloud = mix(combined_noise, cloud_tex, 0.4);
    
    // Aplicação da cobertura e nitidez
    float cloud_mask = smoothstep(1.0 - cloud_coverage, 1.0, final_cloud);
    return pow(cloud_mask, cloud_sharpness);
}

// === CÁLCULO DAS ESTRELAS MELHORADO ===
float get_star_intensity(vec3 view_dir, float time) {
    vec2 star_uv = sphere_project(view_dir);
    star_uv = fract(star_uv * star_texture_scale);
    
    float star_tex = texture(star_texture, star_uv).r;
    
    // Ruído para estrelas procedurais
    vec3 star_pos = view_dir * star_texture_scale * 15.0;
    float star_noise = fbm3(star_pos, 4, 0.5, 2.0);
    star_noise = smoothstep(0.92, 1.0, star_noise);
    
    // Efeito de cintilação
    float twinkle = sin(time * star_twinkle_speed + star_pos.x * 10.0) * 0.3 + 0.7;
    
    float stars = max(star_tex * 0.8, star_noise) * twinkle;
    return stars * star_brightness;
}

// === FUNÇÃO PRINCIPAL DO SHADER ===
void sky() {
    vec3 view_dir = normalize(EYEDIR);
    float current_time = time_of_day;
    
    // Posições do sol e lua
    float sun_angle = current_time * 2.0 * PI;
    vec3 sun_dir = vec3(sin(sun_angle) * 0.1, sin(sun_angle), cos(sun_angle));
    vec3 moon_dir = -sun_dir;
    sun_dir = normalize(sun_dir);
    moon_dir = normalize(moon_dir);
    
    // Cor base do céu
    vec3 sky_color = get_sky_color(view_dir, current_time);
    
    // Espalhamento atmosférico
    vec3 atmosphere = atmospheric_scattering(view_dir, sun_dir, atmosphere_thickness);
    sky_color = mix(sky_color, atmosphere, 0.4);
    
    // Nuvens
    float cloud_factor = get_cloud_density(view_dir, TIME) * cloud_density;
    if (cloud_factor > 0.01) {
        float sun_height = sin(current_time * 2.0 * PI);
        float lighting = max(0.1, sun_height * 0.8 + 0.2);
        
        vec3 cloud_lit = mix(cloud_shadow_color, cloud_color, lighting);
        sky_color = mix(sky_color, cloud_lit, cloud_factor * cloud_thickness);
    }
    
    // Sol
    float sun_dist = distance(view_dir, sun_dir);
    float sun_visibility = smoothstep(-0.05, 0.05, sun_dir.y);
    
    if (use_sun_texture && sun_visibility > 0.01) {
        vec2 sun_uv = (view_dir.xy - sun_dir.xy) / sun_size + 0.5;
        if (sun_uv.x >= 0.0 && sun_uv.x <= 1.0 && sun_uv.y >= 0.0 && sun_uv.y <= 1.0) {
            vec3 sun_tex = texture(sun_texture, sun_uv).rgb;
            float sun_mask = smoothstep(sun_size * 1.2, sun_size * 0.8, sun_dist);
            sky_color = mix(sky_color, sun_tex * sun_color * sun_intensity, 
                           sun_mask * sun_visibility);
        }
    } else {
        float sun_disk = smoothstep(sun_size, sun_size * 0.6, sun_dist);
        float sun_glow = smoothstep(sun_size * 3.0, sun_size * 0.8, sun_dist) * 0.3;
        sky_color = mix(sky_color, sun_color * sun_intensity, 
                       (sun_disk + sun_glow) * sun_visibility);
    }
    
    // Lua
    float moon_dist = distance(view_dir, moon_dir);
    float moon_visibility = smoothstep(-0.05, 0.05, moon_dir.y);
    
    if (use_moon_texture && moon_visibility > 0.01) {
        vec2 moon_uv = (view_dir.xy - moon_dir.xy) / moon_size + 0.5;
        if (moon_uv.x >= 0.0 && moon_uv.x <= 1.0 && moon_uv.y >= 0.0 && moon_uv.y <= 1.0) {
            vec3 moon_tex = texture(moon_texture, moon_uv).rgb;
            float moon_mask = smoothstep(moon_size * 1.2, moon_size * 0.8, moon_dist);
            sky_color = mix(sky_color, moon_tex * moon_color * moon_intensity, 
                           moon_mask * moon_visibility);
        }
    } else {
        float moon_disk = smoothstep(moon_size, moon_size * 0.6, moon_dist);
        float moon_glow = smoothstep(moon_size * 2.0, moon_size * 0.8, moon_dist) * 0.2;
        sky_color = mix(sky_color, moon_color * moon_intensity, 
                       (moon_disk + moon_glow) * moon_visibility);
    }
    
    // Estrelas
    float sun_height = sin(current_time * 2.0 * PI);
    float star_visibility = smoothstep(0.2, -0.2, sun_height);
    
    if (star_visibility > 0.01) {
        float stars = get_star_intensity(view_dir, TIME) * star_visibility;
        stars *= (1.0 - cloud_factor * 0.9); // Estrelas ocultadas pelas nuvens
        sky_color += vec3(stars) * 0.9;
    }
    
    COLOR = sky_color;
}"
