[gd_resource type="Sky" format=3 uid="uid://dq6jehcildox6"]

[sub_resource type="Shader" id="Shader_dufjq"]
code = "shader_type sky;

// -------------------------------------------------------------------------
// 1. CONFIGURAÇÕES DO SOL E DA LUA
// -------------------------------------------------------------------------
group_uniforms Sun_Settings;
uniform vec4 sun_color : source_color = vec4(1.0, 0.9, 0.7, 1.0);
uniform float sun_size : hint_range(0.0, 1.0) = 0.03;
uniform float sun_sharpness : hint_range(1.0, 50.0) = 20.0;
uniform float sun_bloom : hint_range(0.0, 1000.0) = 2.5;

group_uniforms Moon_Settings;
uniform vec4 moon_color : source_color = vec4(0.8, 0.9, 1.0, 1.0); // Azulzinho claro
uniform float moon_size : hint_range(0.0, 1.0) = 0.015; // Lua costuma ser um pouco menor visualmente
uniform float moon_sharpness : hint_range(1.0, 50.0) = 30.0;
uniform float moon_bloom : hint_range(0.0, 1000.0) = 1.0;

// -------------------------------------------------------------------------
// 2. CONFIGURAÇÕES DO CÉU (Fundo)
// -------------------------------------------------------------------------
group_uniforms Sky_Gradient_Day;
uniform vec4 sky_color_top : source_color = vec4(0.2, 0.5, 0.9, 1.0);
uniform vec4 sky_color_horizon : source_color = vec4(0.5, 0.8, 1.0, 1.0);

group_uniforms Sky_Gradient_Night;
uniform vec4 night_color_top : source_color = vec4(0.02, 0.02, 0.05, 1.0);
uniform vec4 night_color_horizon : source_color = vec4(0.05, 0.05, 0.15, 1.0);
uniform vec4 sunset_color : source_color = vec4(1.0, 0.5, 0.2, 1.0);

// -------------------------------------------------------------------------
// 3. CONFIGURAÇÕES DAS NUVENS (Volumetria)
// -------------------------------------------------------------------------
group_uniforms Volumetric_Clouds;
uniform sampler3D noise_texture : filter_linear_mipmap, repeat_enable;
uniform vec4 cloud_color_day : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform vec4 cloud_color_night : source_color = vec4(0.1, 0.1, 0.15, 1.0);

uniform float cloud_scale : hint_range(0.0001, 0.01) = 0.001; 
uniform float density_threshold : hint_range(0.0, 1.0) = 0.4; 
uniform float cloud_density_multiplier : hint_range(0.0, 5.0) = 1.5;

uniform float time_speed = 10.0;
uniform int ray_steps = 32; 

uniform float planet_radius = 50000.0; 
uniform float clouds_bottom = 1500.0;
uniform float clouds_top = 3500.0;

// --- FUNÇÕES AUXILIARES ---
vec2 ray_sphere_intersect(vec3 ro, vec3 rd, float rad) {
	float b = dot(ro, rd);
	float c = dot(ro, ro) - rad * rad;
	float h = b * b - c;
	if (h < 0.0) return vec2(-1.0);
	h = sqrt(h);
	return vec2(-b - h, -b + h);
}

float get_cloud_density(vec3 p, float time) {
	vec3 wind = vec3(time * time_speed, 0.0, 0.0);
	float noise = texture(noise_texture, (p + wind) * cloud_scale).r;
	
	float height_from_surface = length(p) - planet_radius;
	float layer_height = clouds_top - clouds_bottom;
	float relative_height = (height_from_surface - clouds_bottom) / layer_height;
	
	float height_mask = smoothstep(0.0, 0.2, relative_height) * smoothstep(1.0, 0.8, relative_height);
	float density = smoothstep(density_threshold, density_threshold + 0.2, noise);
	
	return density * height_mask * cloud_density_multiplier;
}

float get_cloud_light(vec3 p, float current_density, vec3 sun_dir, float time) {
	float step_dist = 100.0; 
	float density_towards_sun = get_cloud_density(p + sun_dir * step_dist, time);
	
	float transmittance = exp(-density_towards_sun * 2.0);
	return mix(0.3, 1.0, transmittance); 
}

float hash(vec3 p) {
    p  = fract(p * 0.3183099 + .1);
    p *= 17.0;
    return fract(p.x * p.y * p.z * (p.x + p.y + p.z));
}

void sky() {
	vec3 rd = EYEDIR;
	vec3 ro = vec3(0.0, planet_radius, 0.0); 
	
	// --- LÓGICA DO CICLO DIA E NOITE ---
	float sun_height = LIGHT0_DIRECTION.y;
	
	float day_factor = smoothstep(-0.1, 0.1, sun_height);
	float night_factor = 1.0 - day_factor; // Oposto do dia
	float sunset_factor = clamp(1.0 - abs(sun_height * 5.0), 0.0, 1.0);
	
	vec3 current_top_color = mix(night_color_top.rgb, sky_color_top.rgb, day_factor);
	vec3 current_horizon_color = mix(night_color_horizon.rgb, sky_color_horizon.rgb, day_factor);
	current_horizon_color = mix(current_horizon_color, sunset_color.rgb, sunset_factor);
	
	vec3 current_cloud_color = mix(cloud_color_night.rgb, cloud_color_day.rgb, day_factor);
	current_cloud_color = mix(current_cloud_color, sunset_color.rgb, sunset_factor * 0.5);

	// ------------------------------------------
	// 1. DESENHO DO FUNDO (CÉU + ESTRELAS + SOL + LUA)
	// ------------------------------------------
	float sky_factor = smoothstep(0.0, 0.4, rd.y);
	vec3 background_color = mix(current_horizon_color, current_top_color, sky_factor);
	
	// Estrelas
	float star_noise = hash(rd * 200.0); 
	float stars = smoothstep(0.995, 1.0, star_noise); 
	background_color += stars * night_factor; 
	
	// --- SOL (LIGHT0) ---
	float sun_dist = distance(rd, LIGHT0_DIRECTION);
	float sun_disk = smoothstep(sun_size, sun_size - (sun_size * 0.9), sun_dist);
	sun_disk = pow(sun_disk, sun_sharpness);
	vec3 bright_sun_color = sun_color.rgb * (1.0 + sun_bloom);
	
	// Adiciona o Sol (Fica mais forte de dia, some de noite)
	background_color = mix(background_color, bright_sun_color, sun_disk * day_factor);
	
	// --- LUA (LIGHT1) ---
	float moon_dist = distance(rd, LIGHT1_DIRECTION);
	float moon_disk = smoothstep(moon_size, moon_size - (moon_size * 0.9), moon_dist);
	moon_disk = pow(moon_disk, moon_sharpness);
	vec3 bright_moon_color = moon_color.rgb * (1.0 + moon_bloom);
	
	// Adiciona a Lua (Fica mais forte de noite, some de dia)
	background_color = mix(background_color, bright_moon_color, moon_disk * night_factor);
	
	// ------------------------------------------
	// 2. RAYMARCHING DAS NUVENS
	// ------------------------------------------
	float r_inner = planet_radius + clouds_bottom;
	float r_outer = planet_radius + clouds_top;
	
	vec2 hit_inner = ray_sphere_intersect(ro, rd, r_inner);
	vec2 hit_outer = ray_sphere_intersect(ro, rd, r_outer);
	
	float start_dist = 0.0;
	float end_dist = 0.0;
	
	if (hit_inner.y > 0.0) { 
		start_dist = max(0.0, hit_inner.y);
		end_dist = hit_outer.y;
	} else { 
		start_dist = max(0.0, hit_outer.x);
		end_dist = hit_outer.y;
	}
	
	if (start_dist >= end_dist || end_dist < 0.0) {
		COLOR = background_color;
	} else {
		float total_distance = end_dist - start_dist;
		float step_size = total_distance / float(ray_steps);
		vec3 current_pos = ro + rd * start_dist;
		
		vec4 accum_cloud = vec4(0.0); 
		
		for(int i = 0; i < ray_steps; i++) {
			if(accum_cloud.a >= 0.99) break; 
			
			float dens = get_cloud_density(current_pos, TIME);
			
			if(dens > 0.001) {
				// Usa a direção de quem estiver iluminando mais (Sol de dia, Lua de noite)
				vec3 light_dir = mix(LIGHT1_DIRECTION, LIGHT0_DIRECTION, day_factor);
				float light = get_cloud_light(current_pos, dens, light_dir, TIME);
				
				vec3 col = current_cloud_color * light;
				
				col *= dens; 
				accum_cloud.rgb += col * (1.0 - accum_cloud.a);
				accum_cloud.a += dens * (1.0 - accum_cloud.a);
			}
			
			current_pos += rd * step_size;
		}
		
		COLOR = mix(background_color, accum_cloud.rgb, accum_cloud.a);
	}
}"

