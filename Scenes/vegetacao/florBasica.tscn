[sub_resource type="Shader" id="Shader_helwr"]
code = "shader_type spatial;

// render_mode: depth_draw_opaque e cull_disabled são essenciais para grama
render_mode depth_draw_opaque, cull_disabled, specular_schlick_ggx;

// --- Texturas ---
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap_anisotropic, repeat_disable;
uniform vec4 albedo_color : source_color = vec4(1.0);
uniform vec4 transmission : source_color = vec4(0.5, 0.5, 0.5, 1.0);

// --- Configuração do Vento Suave ---
group_uniforms Vento_Suave;
uniform sampler2D noise_tex : filter_linear, repeat_enable; // Use um Noise do tipo Perlin/Simplex
uniform vec2 wind_direction = vec2(1.0, 0.0);
uniform float wind_speed : hint_range(0.0, 2.0) = 0.5;
uniform float wind_strength : hint_range(0.0, 2.0) = 0.5;
uniform float turbulence_scale : hint_range(0.1, 10.0) = 1.0; // Tamanho das ondas

// --- Fade de Distância (Mantido) ---
group_uniforms Distancia;
uniform float fade_start_distance : hint_range(5.0, 500.0) = 40.0;
uniform float fade_end_distance : hint_range(10.0, 500.0) = 60.0;

void vertex() {
	// --- Lógica de Distância (Fade) ---
	float dist = distance(CAMERA_POSITION_WORLD, NODE_POSITION_WORLD);
	float scale_factor = 1.0;
	if (dist > fade_start_distance) {
		scale_factor = 1.0 - smoothstep(fade_start_distance, fade_end_distance, dist);
	}
	
	if (scale_factor <= 0.01) {
		VERTEX = vec3(0.0);
	} else {
		// --- Lógica de Vento \"Soft\" ---
		
		// 1. Identificar altura (0 na base, 1 no topo)
		// Assumindo UV padrão onde Y=1 é base e Y=0 é topo. Se invertido, use (UV.y)
		float height = 1.0 - UV.y;
		
		// Suavização da curva de dobra (Quadrática)
		// Isso faz a base ficar bem fixa e a ponta muito móvel
		float bend_intensity = height * height; 

		// 2. Amostragem do Ruído (Noise)
		vec2 wind_dir_norm = normalize(wind_direction);
		float time_offset = TIME * wind_speed;
		
		// Posição no mundo para variar o vento
		vec2 world_pos = NODE_POSITION_WORLD.xz;
		
		// Amostra principal (Ondas grandes de vento)
		vec2 noise_uv = (world_pos / (10.0 * turbulence_scale)) + (wind_dir_norm * time_offset * 0.05);
		float noise_val = texture(noise_tex, noise_uv).r; // 0.0 a 1.0
		
		// Amostra secundária (Turbulência detalhada) - corre mais rápido em outra direção
		vec2 turbulence_uv = (world_pos / (2.0 * turbulence_scale)) + vec2(time_offset * 0.1);
		float turbulence_val = texture(noise_tex, turbulence_uv).r;

		// Combinar os ruídos para um movimento orgânico (não repetitivo)
		float combined_wind = mix(noise_val, turbulence_val, 0.3);
		
		// Converter [0,1] para [-1, 1] mas com tendência à direção do vento
		// O vento empurra mais para frente (0.2 a 1.2) do que para trás
		float wind_force = (combined_wind * 2.0 - 0.5) * wind_strength;

		// 3. Aplicação do Movimento
		
		// Movimento Principal (Direção do Vento)
		VERTEX.x += wind_dir_norm.x * wind_force * bend_intensity;
		VERTEX.z += wind_dir_norm.y * wind_force * bend_intensity;
		
		// Movimento Lateral (Balanço perpendicular)
		// Usa seno do tempo para criar um balanço suave esquerda/direita
		float side_sway = sin(TIME * wind_speed + world_pos.x) * (wind_strength * 0.3);
		VERTEX.x += wind_dir_norm.y * side_sway * bend_intensity; // Perpendicular X
		VERTEX.z -= wind_dir_norm.x * side_sway * bend_intensity; // Perpendicular Z

		// 4. Compensação de Altura (O Segredo da Suavidade)
		// Se a grama dobra pro lado, ela tem que descer um pouco.
		// Sem isso, ela parece esticar.
		float displacement = length(vec2(wind_force, side_sway)) * bend_intensity;
		VERTEX.y -= displacement * 0.3; // 0.3 é um fator mágico de compensação

		// Aplica o fade de distância no final
		VERTEX *= scale_factor;
	}
}

void fragment() {
	vec4 albedo_tex = texture(texture_albedo, UV);
	ALBEDO = albedo_color.rgb * albedo_tex.rgb;
	
	// Ajustes visuais para parecer vegetação
	METALLIC = 0.0;
	ROUGHNESS = 0.8; 
	SPECULAR = 0.1; // Vegetação geralmente tem pouco brilho especular direto
	
	// ALPHA SCISSOR para recorte perfeito
	ALPHA = albedo_tex.a;
	ALPHA_SCISSOR_THRESHOLD = 0.5;
	
	// Luz de fundo (Translucência)
	// Isso faz a grama brilhar quando o sol está atrás dela
	vec3 backlight_color = transmission.rgb * (1.0 - albedo_tex.rgb);
	BACKLIGHT = backlight_color * 1.5;
	
	// Normal Map falso para dar volume (opcional, ajuda no visual)
	NORMAL = mix(NORMAL, vec3(0.0, 1.0, 0.0), 0.5);
}"

