shader_parameter/albedo_color = Color(0.65625, 0.65625, 0.65625, 1)
shader_parameter/transmission = Color(1, 1, 1, 1)
shader_parameter/alpha_scissor_threshold = 0.5
shader_parameter/wind_speed = 2.000000095
shader_parameter/wind_strength = 0.02000000095
shader_parameter/leaf_flutter = 0.02000000095
shader_parameter/use_height_based_stiffness = false
shader_parameter/height_falloff = 0.010000000475
shader_parameter/fade_start = 500.0
shader_parameter/fade_end = 500.0

