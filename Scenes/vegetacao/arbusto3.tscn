[sub_resource type="Shader" id="Shader_khyk1"]
code = "shader_type spatial;
render_mode depth_draw_opaque, cull_disabled, specular_schlick_ggx;

// --- Visual ---
uniform sampler2D texture_albedo : source_color, filter_linear_mipmap_anisotropic, repeat_disable;
uniform vec4 albedo_color : source_color = vec4(1.0);
uniform vec4 transmission : source_color = vec4(0.5, 0.6, 0.1, 1.0);
uniform float alpha_scissor_threshold : hint_range(0.0, 1.0) = 0.5;

// --- Vento ---
group_uniforms Vento;
uniform float wind_speed : hint_range(0.0, 5.0) = 1.0;
uniform float wind_strength : hint_range(0.0, 2.0) = 0.15;
uniform float leaf_flutter : hint_range(0.0, 1.0) = 0.1;

// --- Rigidez ---
group_uniforms Rigidez;
uniform bool use_height_based_stiffness = true;
uniform float height_falloff : hint_range(0.0, 50.0) = 5.0;

// --- Distância ---
group_uniforms Distancia;
uniform float fade_start : hint_range(0.0, 500.0) = 40.0;
uniform float fade_end : hint_range(0.0, 500.0) = 60.0;

varying float alpha_threshold;

void vertex() {
	vec3 world_pos = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz;

	// Fade calculado no vertex — evita recalcular por fragmento
	float dist = distance(CAMERA_POSITION_WORLD, world_pos);
	float fade = smoothstep(fade_start, fade_end, dist);
	alpha_threshold = clamp(alpha_scissor_threshold + fade, 0.0, 1.0);

	// Rigidez sem branch via mix — GPU-friendly
	float stiffness = mix(COLOR.r, smoothstep(0.0, height_falloff, VERTEX.y),
	                      float(use_height_based_stiffness));

	// Vento
	float t = TIME * wind_speed;
	vec2 nxz = NODE_POSITION_WORLD.xz;

	float sway_x = sin(t + nxz.x * 0.5 + nxz.y * 0.3)
	             + cos(t * 0.8  + nxz.x * 0.2) * 0.5;
	float sway_z = sin(t * 0.9  + nxz.y * 0.5 + nxz.x * 0.3 + 5.0)
	             + cos(t * 0.72 + nxz.y * 0.2) * 0.5;

	float shiver = sin(t * 8.0 + world_pos.x * 10.0 + world_pos.z * 5.0 + world_pos.y)
	               * leaf_flutter;

	// Deslocamento final — stiffness aplicado uma vez
	vec3 wind_offset = vec3(
		sway_x * wind_strength + NORMAL.x * shiver,
		NORMAL.y * shiver,
		sway_z * wind_strength + NORMAL.z * shiver
	);
	VERTEX += wind_offset * stiffness;
}

void fragment() {
	vec4 albedo_tex = texture(texture_albedo, UV);

	ALBEDO = albedo_color.rgb * albedo_tex.rgb;
	ROUGHNESS = 0.8;
	SPECULAR  = 0.2;
	ALPHA = albedo_tex.a;
	ALPHA_SCISSOR_THRESHOLD = alpha_threshold;

	// Backlight sem o termo ALBEDO redundante
	BACKLIGHT = transmission.rgb * (1.0 - albedo_tex.rgb);
}"

