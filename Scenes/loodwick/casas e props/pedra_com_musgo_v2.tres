[sub_resource type="Shader" id="Shader_6nieq"]
code = "shader_type spatial;

// --- CORES (TINT) ---
group_uniforms colors;
// source_color garante que o Godot mostre o seletor de cores no Inspector e aplique o sRGB correto
uniform vec4 tint_base : source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform vec4 tint_moss : source_color = vec4(1.0, 1.0, 1.0, 1.0);
group_uniforms;

// --- CONTROLES DE UV ---
group_uniforms uv_controls;
uniform vec2 uv_scale_base = vec2(1.0, 1.0);
uniform vec2 uv_offset_base = vec2(0.0, 0.0);

uniform vec2 uv_scale_moss = vec2(1.0, 1.0);
uniform vec2 uv_offset_moss = vec2(0.0, 0.0);

uniform vec2 uv_scale_mask = vec2(1.0, 1.0);
uniform vec2 uv_offset_mask = vec2(0.0, 0.0);
group_uniforms;

// --- TEXTURAS DE COR (ALBEDO) ---
group_uniforms albedo;
uniform sampler2D albedo_base : source_color, filter_linear_mipmap;
uniform sampler2D albedo_moss : source_color, filter_linear_mipmap;
group_uniforms;

// --- TEXTURAS DE RELEVO (NORMAL MAP) ---
group_uniforms normals;
uniform sampler2D normal_base : hint_normal, filter_linear_mipmap;
uniform sampler2D normal_moss : hint_normal, filter_linear_mipmap;
group_uniforms;

// --- TEXTURAS DE RUGOSIDADE (ROUGHNESS) ---
group_uniforms roughness;
uniform sampler2D roughness_base : hint_default_white, filter_linear_mipmap;
uniform sampler2D roughness_moss : hint_default_white, filter_linear_mipmap;
group_uniforms;

// --- MÁSCARA E CONTROLES DE ALTURA ---
group_uniforms moss_settings;
uniform sampler2D moss_mask : hint_default_white, filter_linear_mipmap;
uniform float moss_amount : hint_range(0.0, 1.0) = 1.0;
uniform bool grow_from_top = false; 
uniform float height_offset = 0.0;
uniform float height_falloff = 1.0;
group_uniforms;

varying float local_y;

void vertex() {
    local_y = VERTEX.y;
}

void fragment() {
    // --- 0. CÁLCULO DAS UVS INDEPENDENTES ---
    vec2 uv_base = UV * uv_scale_base + uv_offset_base;
    vec2 uv_moss = UV * uv_scale_moss + uv_offset_moss;
    vec2 uv_mask = UV * uv_scale_mask + uv_offset_mask;

    // --- 1. CÁLCULO DA MÁSCARA ---
    float mask_value = texture(moss_mask, uv_mask).r;
    
    // Calcula a distância do offset baseada na direção escolhida (cima ou baixo)
    float height_distance = grow_from_top ? (height_offset - local_y) : (local_y - height_offset);
    
    // Aplica o falloff na distância calculada
    float height_factor = 1.0 - (height_distance * height_falloff);
    height_factor = clamp(height_factor, 0.0, 1.0);
    
    float final_moss_mask = clamp(mask_value * height_factor * moss_amount, 0.0, 1.0);

    // --- 2. APLICAÇÃO DA COR COM O TINT ---
    // Multiplicamos a textura pelo tint escolhido no Inspector
    vec3 color_base = texture(albedo_base, uv_base).rgb * tint_base.rgb;
    vec3 color_moss = texture(albedo_moss, uv_moss).rgb * tint_moss.rgb;
    ALBEDO = mix(color_base, color_moss, final_moss_mask);

    // --- 3. APLICAÇÃO DO RELEVO (NORMAL MAP) ---
    vec3 norm_base = texture(normal_base, uv_base).rgb;
    vec3 norm_moss = texture(normal_moss, uv_moss).rgb;
    NORMAL_MAP = mix(norm_base, norm_moss, final_moss_mask);

    // --- 4. APLICAÇÃO DA RUGOSIDADE (ROUGHNESS) ---
    float rough_base = texture(roughness_base, uv_base).r;
    float rough_moss = texture(roughness_moss, uv_moss).r;
    ROUGHNESS = mix(rough_base, rough_moss, final_moss_mask);
}"

